NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: Server-side OpenAI key for API route proxy at /api/enhance.
# If unset, the route can still accept x-openai-key from the client.
OPENAI_API_KEY=

# Optional: Set to false to force legacy browser-side OpenAI calls.
NEXT_PUBLIC_OPENAI_SERVER_PROXY=true

# Optional: Force strict server-only mode (disables browser fallback path).
NEXT_PUBLIC_OPENAI_STRICT_SERVER_ONLY=false
